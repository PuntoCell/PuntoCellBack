generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("PRISMA_DATABASE_URL")
}

model Localidad {
  id        Int         @id(map: "PK__Localida__3214EC07194FDF52") @default(autoincrement()) @map("Id")
  nombre    String      @map("Nombre") @db.NVarChar(100)
  Cliente   Cliente[]
  Empleado  Empleado[]
  Proveedor Proveedor[]
  Sucursal  Sucursal[]
  Usuario   Usuario[]

  @@map("Localidad")
}

model Rol {
  id          Int          @id(map: "PK__Rol__3214EC076A92B61C") @default(autoincrement()) @map("Id")
  Nombre      String       @db.NVarChar(100)
  Activo      Boolean
  Empleado    Empleado[]
  rolPermisos RolPermiso[]
  Usuario     Usuario[]

  @@map("Rol")
}

model Permiso {
  id          Int          @id(map: "PK__Permiso__3214EC07A6D78F56") @default(autoincrement()) @map("Id")
  Recurso     String       @db.NVarChar(100)
  Accion      String       @db.NVarChar(50)
  Nombre      String       @db.NVarChar(150)
  rolPermisos RolPermiso[]

  @@unique([Recurso, Accion], map: "UQ_Permiso")
  @@map("Permiso")
}

model RolPermiso {
  rolId     Int     @map("IdRol")
  permisoId Int     @map("IdPermiso")
  permiso   Permiso @relation(fields: [permisoId], references: [id], onUpdate: NoAction, map: "FK_RolPermiso_Permiso")
  rol       Rol     @relation(fields: [rolId], references: [id], onUpdate: NoAction, map: "FK_RolPermiso_Rol")

  @@id([rolId, permisoId], map: "PK__RolPermi__BA9F7EA03122B29F")
  @@map("RolPermiso")
}

model Accion {
  Id       Int        @id(map: "PK__Accion__3214EC07CC08CE08") @default(autoincrement())
  Nombre   String     @db.NVarChar(100)
  Bitacora Bitacora[]
}

